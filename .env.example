# Alice Agent 环境变量模板

# LLM API 配置 (必需) -- 只推荐使用glm4.7
API_KEY=your_api_key_here
MODEL_NAME=ZhipuAI/GLM-4.7
API_BASE_URL=
# 可选：JSON 数组，按请求轮询 header profiles
# 所有请求都会强制带上 User-Agent: curl/8.0.0；这里可覆盖其它头字段：
# REQUEST_HEADER_PROFILES=[{"User-Agent":"curl/8.0.0","Accept":"*/*","Connection":"keep-alive"},{"User-Agent":"curl/8.0.0","Accept":"application/json","Connection":"keep-alive","Cache-Control":"no-cache"},{"User-Agent":"curl/8.0.0","Accept":"*/*","Connection":"close","Pragma":"no-cache"}]
