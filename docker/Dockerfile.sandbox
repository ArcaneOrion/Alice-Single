# Alice Agent 轻量运行镜像
# 单容器承载 agent，本地进程直接执行 bash / python

FROM python:3.11-slim

ENV DEBIAN_FRONTEND=noninteractive \
    LANG=C.UTF-8 \
    LC_ALL=C.UTF-8 \
    PYTHONUNBUFFERED=1

WORKDIR /app

RUN apt-get update && apt-get install -y --no-install-recommends \
    bash \
    ca-certificates \
    curl \
    git \
    nodejs \
    npm \
    procps \
    && python -m pip install --no-cache-dir --upgrade pip setuptools wheel \
    && python -m pip install --no-cache-dir openai python-dotenv \
    && rm -rf /var/lib/apt/lists/*

RUN useradd --create-home --shell /bin/bash alice \
    && mkdir -p /app/.alice /app/skills /workspace \
    && chown -R alice:alice /app /workspace /home/alice

USER alice

CMD ["/bin/bash"]
